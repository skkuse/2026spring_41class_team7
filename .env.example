# Copy this file to .env in the repo root for local development:
#   cp .env.example .env
#
# In production (Railway), set these in the service's Variables tab.
# Railway Postgres plugin injects DATABASE_URL automatically.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team7?schema=public"

# ── Server (Railway sets these automatically) ─────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS — comma-separated allowed origins ────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Supabase (same project as apps/web NEXT_PUBLIC_* vars) ───────────────────
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── OpenAI (resume parse + GitHub tech inference) ─────────────────────────────
OPENAI_API_KEY=
# Optional; defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ── GitHub (optional — higher rate limits / private repo access) ──────────────
# If unset, the API falls back to `gh auth token` (gh CLI login).
# Run `gh auth login` once and you won't need this variable at all.
GITHUB_TOKEN=

# ── Cloudflare R2 (S3-compatible document storage) ───────────────────────────
# See docs/cloudflare-r2-hono.md for architecture details.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
