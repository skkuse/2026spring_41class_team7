DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team7?schema=public"

# Same Supabase project as apps/web (.env.local NEXT_PUBLIC_*)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
# Comma-separated origins for browser clients (Next.js on :3000)
CORS_ORIGIN=http://localhost:3000

# OpenAI (resume parse + GitHub tech inference)
OPENAI_API_KEY=
# Optional; default gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional GitHub token for higher rate limits and private repos you can access
GITHUB_TOKEN=

# --- Cloudflare R2 (S3-compatible user document storage) ---
# See docs/cloudflare-r2-hono.md for architecture (presigned upload vs proxied upload).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# Optional: public base URL if you serve some objects via custom domain / public bucket
# R2_PUBLIC_URL=
