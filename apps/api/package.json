{
  "name": "@jobclaw/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env watch src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "tsx --env-file=../../.env src/scripts/reset.ts",
    "build": "tsc -p tsconfig.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "start:dev": "node --env-file=../../.env dist/index.js",
    "test": "vitest run",
    "test:fixtures": "node scripts/build-test-fixtures.mjs",
    "test:resume:local": "node scripts/test-resume-parse-local.mjs",
    "lint": "echo 'No lint configured for api'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "@hono/zod-openapi": "latest",
    "@jobclaw/shared-types": "workspace:*",
    "@prisma/client": "^6.19.2",
    "@scalar/hono-api-reference": "latest",
    "@supabase/supabase-js": "^2.100.0",
    "hono": "latest",
    "mammoth": "^1.12.0",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "resend": "^6.12.4",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.2",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^4.1.1"
  }
}
