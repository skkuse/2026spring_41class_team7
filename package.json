{
  "name": "jobclaw-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:cli": "pnpm --filter jobclaw build",
    "assess:api": "pnpm build:cli && pnpm exec jobclaw assess apps/api --type node-backend --out apps/api/assessments/latest.md",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "jobclaw": "jobclaw",
    "projects": "pnpm --filter @jobclaw/project-management exec tsx src/cli.ts",
    "export-pdf": "node export-pdf.mjs"
  },
  "devDependencies": {
    "jobclaw": "workspace:*",
    "puppeteer-core": "^23.0.0",
    "turbo": "latest",
    "typescript": "latest"
  }
}
